{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "transition.js", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/transition.js", "dest": "/transition.js" },
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/favicon/(.*)", "dest": "/public/favicon/$1" },
    { "src": "/(.*\\.(png|gif|jpg|jpeg|svg|ico|webp|js|css|json|webmanifest))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
